{
    "preset": "laravel",
    "exclude": [
        "bootstrap",
        "storage",
        "vendor",
        "node_modules",
        "public/build",
        "public/storage"
    ],
    "rules": {
        "array_syntax": {
            "syntax": "short"
        },
        "ordered_imports": {
            "sort_algorithm": "alpha"
        },
        "no_unused_imports": true,
        "single_quote": true,
        "trailing_comma_in_multiline": {
            "elements": ["arrays"]
        },
        "phpdoc_align": false,
        "phpdoc_no_empty_return": false,
        "phpdoc_order": true,
        "phpdoc_trim": true,
        "phpdoc_separation": false,
        "class_attributes_separation": {
            "elements": {
                "method": "one",
                "property": "one",
                "const": "none"
            }
        },
        "method_chaining_indentation": true,
        "types_spaces": {
            "space": "single"
        },
        "binary_operator_spaces": {
            "default": "single_space"
        }
    }
}
